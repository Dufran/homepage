{
	"dependencies": {
		"@astrojs/rss": "^4.0.19",
		"@astrojs/sitemap": "^3.7.3",
		"astro": "^7.0.7",
		"astro-mermaid": "^2.1.0",
		"mermaid": "^11.16.0"
	},
	"description": "Astro portfolio and Markdown blog inspired by AstroPaper",
	"devDependencies": {
		"@astrojs/check": "^0.9.9",
		"@biomejs/biome": "2.5.4",
		"typescript": "6.0.3",
		"wrangler": "^4.107.0"
	},
	"name": "homepage",
	"packageManager": "yarn@4.17.0",
	"private": true,
	"scripts": {
		"build": "astro check && astro build",
		"check": "astro check && biome check .",
		"deploy": "yarn build && wrangler pages deploy dist",
		"dev": "astro dev",
		"format": "biome format --write .",
		"lint:fix": "biome check --write --unsafe .",
		"lint:read": "biome check .",
		"preview": "astro preview",
		"typecheck": "astro check"
	},
	"version": "1.0.0"
}
