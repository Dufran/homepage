---
import Header from '../components/Header.astro'
import '../styles/global.css'

type Props = {
  description?: string
  image?: string
  imageAlt?: string
  imageHeight?: number
  imageWidth?: number
  modifiedTime?: Date
  ogType?: 'article' | 'website'
  publishedTime?: Date
  structuredData?: Record<string, unknown>
  tags?: string[]
  title: string
}

const {
  description = 'Full-stack and infrastructure engineer experienced with Python, Django, React, TypeScript, PostgreSQL, Docker, Linux, integrations, deployment automation, and production systems.',
  image = '/og-default.jpg',
  imageAlt = 'Oleksandr Korol — Software Engineer for fullstack systems, infrastructure, and automation',
  imageHeight = 630,
  imageWidth = 1200,
  modifiedTime,
  ogType = 'website',
  publishedTime,
  structuredData,
  tags = [],
  title,
} = Astro.props
const canonicalURL = new URL(Astro.url.pathname, Astro.site)
const imageURL = new URL(image, Astro.site)
const serializedStructuredData = structuredData
  ? JSON.stringify(structuredData).replaceAll('<', '\\u003c')
  : undefined
---

<!doctype html>
<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <link rel='preload' href='/fonts/inter-latin-400-700.woff2' as='font' type='font/woff2' crossorigin />
    <link rel='preload' href='/fonts/ibm-plex-mono-latin-400.woff2' as='font' type='font/woff2' crossorigin />
    <link rel='preload' href='/fonts/ibm-plex-mono-latin-700.woff2' as='font' type='font/woff2' crossorigin />
    <style is:inline>
      body {
        font-family: 'Inter', ui-sans-serif, system-ui, sans-serif;
        line-height: 1.65;
        margin: 0;
      }
    </style>
    <meta name='description' content={description} />
    <meta name='author' content='Oleksandr Korol' />
    <meta name='robots' content='index, follow, max-image-preview:large' />
    <meta name='generator' content={Astro.generator} />
    <meta name='theme-color' content='#fdfdfd' media='(prefers-color-scheme: light)' />
    <meta name='theme-color' content='#161a1d' media='(prefers-color-scheme: dark)' />
    <link rel='icon' type='image/svg+xml' href='/favicon.svg' />
    <link rel='canonical' href={canonicalURL} />
    <link rel='alternate' type='application/rss+xml' title='Oleksandr Korol' href='/rss.xml' />
    <meta property='og:type' content={ogType} />
    <meta property='og:site_name' content='Oleksandr Korol' />
    <meta property='og:locale' content='en_US' />
    <meta property='og:title' content={title} />
    <meta property='og:description' content={description} />
    <meta property='og:url' content={canonicalURL} />
    <meta property='og:image' content={imageURL} />
    <meta property='og:image:alt' content={imageAlt} />
    <meta property='og:image:width' content={String(imageWidth)} />
    <meta property='og:image:height' content={String(imageHeight)} />
    {publishedTime && <meta property='article:published_time' content={publishedTime.toISOString()} />}
    {modifiedTime && <meta property='article:modified_time' content={modifiedTime.toISOString()} />}
    {ogType === 'article' && <meta property='article:author' content='https://dufran.org/' />}
    {tags.map((tag) => <meta property='article:tag' content={tag} />)}
    <meta name='twitter:card' content='summary_large_image' />
    <meta name='twitter:title' content={title} />
    <meta name='twitter:description' content={description} />
    <meta name='twitter:image' content={imageURL} />
    <meta name='twitter:image:alt' content={imageAlt} />
    {serializedStructuredData && (
      <script is:inline type='application/ld+json' set:html={serializedStructuredData} />
    )}
    <script is:inline>
      const storedTheme = localStorage.getItem('theme')
      const preferredTheme = matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'
      document.documentElement.dataset.theme = storedTheme || preferredTheme
    </script>
    <title>{title}</title>
  </head>
  <body>
    <a class='skip-link' href='#main-content'>Skip to content</a>
    <div class='site-shell'>
      <Header />
      <main id='main-content'>
        <slot />
      </main>
      <footer>© {new Date().getFullYear()} Oleksandr Korol · Built with Astro</footer>
    </div>
  </body>
</html>
