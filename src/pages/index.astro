---
import {
  coaxProjects,
  coaxSkills,
  domains,
  getSkillProficiency,
  planeksProjects,
  planeksSkills,
  SocialLinks,
  sebnProjects,
  sebnSkills,
  tools,
} from '../data/portfolio'
import BaseLayout from '../layouts/BaseLayout.astro'

const allSkills = [...sebnSkills, ...coaxSkills, ...planeksSkills, ...tools]
const uniqueSkills = [...new Map(allSkills.map((skill) => [skill.label, skill])).values()]
const skillGroups = [
  {
    description:
      'Primary, sustained production stack; I can lead design, implementation, and troubleshooting.',
    label: 'Core',
    value: 'core',
  },
  {
    description: 'Shipped in production and comfortable working independently.',
    label: 'Proficient',
    value: 'proficient',
  },
  {
    description: 'Used in a narrower context; not claiming deep expertise.',
    label: 'Familiar',
    value: 'familiar',
  },
] as const
const experienceStart = new Date('2020-02-01')
const experienceYears = Math.floor((Date.now() - experienceStart.getTime()) / 31_556_952_000)
const projectCount = sebnProjects.length + coaxProjects.length + planeksProjects.length
const experiences = [
  {
    company: 'PLANEKS',
    count: planeksProjects.length,
    description:
      'As a Fullstack Python/JS Developer at Planeks, I lead the development of scalable web applications by leveraging both back-end and front-end technologies. My role involves designing and implementing efficient server-side logic using Python, integrating with various databases, and ensuring a seamless user experience through responsive front-end development.',
    role: 'Fullstack Developer',
    start: new Date('2023-11-01'),
  },
  {
    company: 'COAX Software',
    count: coaxProjects.length,
    description:
      'As a Middle Python Developer at COAX Software, I focused on backend development using Django Rest Framework and FastAPI, contributing to a variety of projects. I collaborated closely with cross-functional teams to deliver high-quality software solutions, consistently applying best practices in code quality, security, and performance optimization.',
    end: new Date('2023-11-01'),
    role: 'Middle Python Developer',
    start: new Date('2022-06-01'),
  },
  {
    company: 'SEBN',
    count: sebnProjects.length,
    description:
      'As a Software Engineer at SEBN, I gained deep insights into various production processes, including logistics, planning, and network infrastructure. I identified and investigated bottlenecks, collaborating closely with different company departments to design and implement software solutions that addressed those challenges. My role involved working hand in hand with clients, taking projects from initial concept through to the final product, ensuring that the software delivered met both technical requirements and business needs.',
    end: new Date('2022-06-01'),
    role: 'Software Engineer',
    start: new Date('2020-02-01'),
  },
]
const monthsBetween = (start: Date, end = new Date()) =>
  (end.getFullYear() - start.getFullYear()) * 12 + end.getMonth() - start.getMonth()
const startedAgo = (start: Date) => {
  const years = Math.floor(monthsBetween(start) / 12)
  return years > 0 ? `${years} ${years === 1 ? 'year' : 'years'}` : `${monthsBetween(start)} months`
}
const recognition = [
  'Expertise in backend development with a strong focus on performance optimization, unit testing, and security.',
  'Building intuitive, user-friendly interfaces with React, always considering the end-user experience and suggesting improvements on the spot.',
  'Deep knowledge of Unix-based systems, deployment workflows, and server management — also a homelab and self-hosting enthusiast.',
  'Effective collaboration with cross-functional teams to deliver high-quality software solutions.',
  'Strong organizational skills with a history of managing project tasks efficiently.',
  'Continuously staying informed about emerging technologies and trends, and proactively identifying the best tools and practices to improve productivity and software quality.',
  'A product-first approach: consistently aligning development decisions with business goals and end-user needs.',
  'Time-conscious and automation-focused, reducing manual overhead in favor of spending more time solving meaningful business problems with code.',
]
---

<BaseLayout title='Oleksandr Korol — Fullstack Engineer'>
  <div class='wide-content'>
    <header>
      <p class='eyebrow'>Portfolio</p>
      <h1>👋 Hello there!</h1>
      <p class='lede'>Fullstack Python and JavaScript engineer building scalable, product-focused web applications.</p>
    </header>

    <div class='page-with-outline'>
      <aside class='outline-nav' aria-label='On this page'>
        <p>On this page</p>
        <a href='#about'>About</a>
        <a href='#experience'>Work experience</a>
        <a href='#skills'>Skills</a>
      </aside>
      <div class='page-sections'>
    <section id='about' class='profile-grid' aria-labelledby='about-title'>
      <div class='card profile-card'>
        <img class='avatar' src='/profile.jpg' alt='Oleksandr Korol' width='128' height='128' />
        <h2 id='about-title'>Oleksandr Korol</h2>
        <p class='muted'>Fullstack engineer</p>
        <div class='stat-list'>
          <div><strong>Experience:</strong> {experienceYears}+ years</div>
          <div><strong>Projects done:</strong> {projectCount}</div>
          <div><strong>Languages:</strong> English B2 · German A2 · Ukrainian C2</div>
          <div><strong>Domains:</strong><div class='tags'>{domains.map((domain) => <span class='tag'>{domain}</span>)}</div></div>
        </div>
        <h3>Find me online</h3>
        <ul class='social-list'>
          {SocialLinks.map((link) => <li><a href={link.url}><span aria-hidden='true'>{link.icon}</span>{link.label}</a></li>)}
        </ul>
      </div>
      <div>
        <h2>Fullstack Python/JavaScript Developer</h2>
        <p>Experienced in designing and implementing scalable web applications using modern frameworks such as Django, FastAPI, and React. Known for adaptability, accountability, and strong problem-solving abilities, with a proven track record of delivering robust solutions aligned with project goals and industry best practices. Brings a strong product-oriented mindset and thrives in dynamic startup environments, with extensive experience building projects from the ground up.</p>
        <p>Driven by time efficiency — if part of a workflow can be automated, I’ll automate it using the best available tools. This helps free up time for what I enjoy most: writing clean, effective code to solve real business challenges.</p>
        <h3>Recognized for</h3>
        <ul class='recognition-list'>{recognition.map((item) => <li>{item}</li>)}</ul>
      </div>
    </section>

    <section id='experience' aria-labelledby='timeline-title'>
      <h2 id='timeline-title'>Work experience</h2>
      <ol class='timeline'>
        {experiences.map((experience) => (
          <li>
            <div class='timeline-head'><h3>{experience.company}</h3><span class='tag'>{experience.role}</span></div>
            <p class='post-meta'>{startedAgo(experience.start)} ago for {monthsBetween(experience.start, experience.end)} months · {experience.count} projects {experience.end ? '' : '· Current'}</p>
            <p>{experience.description}</p>
          </li>
        ))}
      </ol>
    </section>

    <section id='skills' aria-labelledby='skills-title'>
      <h2 id='skills-title'>Skills</h2>
      <p class='muted'>Qualitative levels based on repeated project work and hands-on delivery—not percentages or certifications.</p>
      <div class='form-control skill-picker'>
        <label for='skill-search'>Search skills</label>
        <input id='skill-search' type='search' placeholder='Try Django, React, PostgreSQL…' autocomplete='off' />
      </div>
      <p id='skill-feedback' class='skill-feedback' aria-live='polite'>Select skills to see how well we match.</p>
      {skillGroups.map((group) => (
        <div class='skill-group' data-skill-group>
          <h3>{group.label}</h3>
          <p class='muted'>{group.description}</p>
          <div class='skill-cloud' aria-label={`${group.label} skills`}>
            {uniqueSkills
              .filter((skill) => getSkillProficiency(skill.label) === group.value)
              .map((skill) => <button class='skill-chip' type='button' aria-pressed='false' data-label={skill.label}>{skill.label}</button>)}
          </div>
        </div>
      ))}
    </section>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const search = document.querySelector<HTMLInputElement>('#skill-search')
  const chips = [...document.querySelectorAll<HTMLButtonElement>('.skill-chip')]
  const feedback = document.querySelector<HTMLParagraphElement>('#skill-feedback')
  const messages = [
    'Select skills to see how well we match.',
    'Great start — that skill is in my toolkit.',
    'Perfect match! These skills are right up my alley. 🎯',
    "We've got a winner — exactly what you're looking for. 🏆",
    'Bingo! This combination is in my toolkit. 🎉',
    "Jackpot! I've got these skills covered. 💰",
  ]
  const updateFeedback = () => {
    const selected = chips.filter((chip) => chip.ariaPressed === 'true').length
    if (feedback) feedback.textContent = selected > 5 ? `Mic drop! ${selected} matching skills. 🎤` : messages[selected]
  }
  search?.addEventListener('input', () => {
    const term = search.value.trim().toLowerCase()
    for (const chip of chips) chip.hidden = !chip.dataset.label?.toLowerCase().includes(term)
    for (const group of document.querySelectorAll<HTMLElement>('[data-skill-group]')) {
      group.hidden = ![...group.querySelectorAll<HTMLButtonElement>('.skill-chip')].some((chip) => !chip.hidden)
    }
  })
  for (const chip of chips) {
    chip.addEventListener('click', () => {
      chip.ariaPressed = chip.ariaPressed === 'true' ? 'false' : 'true'
      updateFeedback()
    })
  }
</script>
