---
import {
  coaxProjects,
  coaxSkills,
  cvProfile,
  cvSkillGroups,
  domains,
  getSkillProficiency,
  planeksProjects,
  planeksSkills,
  SocialLinks,
  sebnProjects,
  sebnSkills,
  tools,
  workExperiences,
} from '../data/portfolio'
import BaseLayout from '../layouts/BaseLayout.astro'

const allSkills = [...sebnSkills, ...coaxSkills, ...planeksSkills, ...tools]
const uniqueSkills = [...new Map(allSkills.map((skill) => [skill.label, skill])).values()]
const skillGroups = [
  {
    description:
      'Primary, sustained production stack; I can lead design, implementation, and troubleshooting.',
    label: 'Core',
    value: 'core',
  },
  {
    description: 'Shipped in production and comfortable working independently.',
    label: 'Proficient',
    value: 'proficient',
  },
  {
    description: 'Used in a narrower context; not claiming deep expertise.',
    label: 'Familiar',
    value: 'familiar',
  },
] as const
const experienceStart = new Date('2020-02-01')
const currentExperience = workExperiences.find((experience) => !experience.end)
const experienceYears = Math.floor((Date.now() - experienceStart.getTime()) / 31_556_952_000)
const projectCount = sebnProjects.length + coaxProjects.length + planeksProjects.length
const projectCounts = {
  'COAX Software': coaxProjects.length,
  PLANEKS: planeksProjects.length,
  SEBN: sebnProjects.length,
}
const monthsBetween = (start: Date, end = new Date()) =>
  (end.getFullYear() - start.getFullYear()) * 12 + end.getMonth() - start.getMonth()
const startedAgo = (start: Date) => {
  const years = Math.floor(monthsBetween(start) / 12)
  return years > 0 ? `${years} ${years === 1 ? 'year' : 'years'}` : `${monthsBetween(start)} months`
}
const homeStructuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@id': `${cvProfile.website}/#person`,
      '@type': 'Person',
      description: cvProfile.professionalSummary,
      email: `mailto:${cvProfile.email}`,
      hasOccupation: {
        '@type': 'Occupation',
        description: cvProfile.tagline,
        name: cvProfile.title,
        skills: cvSkillGroups.flatMap((group) => group.skills),
      },
      image: new URL('/profile-512.webp', Astro.site).href,
      jobTitle: cvProfile.title,
      knowsAbout: cvSkillGroups.flatMap((group) => group.skills),
      knowsLanguage: cvProfile.languages.map((language) => ({
        '@type': 'Language',
        name: language,
      })),
      name: cvProfile.name,
      sameAs: [cvProfile.linkedIn, cvProfile.github],
      url: cvProfile.website,
      ...(currentExperience && {
        worksFor: {
          '@type': 'Organization',
          name: currentExperience.company,
        },
      }),
    },
    {
      '@id': `${cvProfile.website}/#website`,
      '@type': 'WebSite',
      author: { '@id': `${cvProfile.website}/#person` },
      description: cvProfile.professionalSummary,
      inLanguage: 'en',
      name: `${cvProfile.name} — Portfolio and engineering notes`,
      url: cvProfile.website,
    },
  ],
}
---

<BaseLayout title={`${cvProfile.name} — Full-stack Developer & Infrastructure Engineer`} structuredData={homeStructuredData}>
  <div class='wide-content'>
    <header>
      <p class='eyebrow'>Portfolio</p>
      <h1>Oleksandr Korol — Full-stack Developer & Infrastructure Engineer</h1>
      <p class='lede'>{cvProfile.tagline}</p>
    </header>

    <div class='page-with-outline'>
      <aside class='outline-nav' aria-label='On this page'>
        <p>On this page</p>
        <a href='#about'>About</a>
        <a href='#experience'>Work experience</a>
        <a href='#skills'>Skills</a>
      </aside>
      <div class='page-sections'>
    <section id='about' class='profile-grid' aria-labelledby='about-title'>
      <div class='card profile-card'>
        <img
          class='avatar'
          src='/profile-256.webp'
          srcset='/profile-256.webp 1x, /profile-512.webp 2x'
          alt='Oleksandr Korol'
          width='128'
          height='128'
          decoding='async'
        />
        <h2 id='about-title'>Oleksandr Korol</h2>
        <p class='muted'>{cvProfile.shortTitle}</p>
        <div class='stat-list'>
          <div><strong>Experience:</strong> {experienceYears}+ years</div>
          <div><strong>Projects done:</strong> {projectCount}</div>
          <div><strong>Languages:</strong> English B2 · German A2 · Ukrainian C2</div>
          <div><strong>Domains:</strong><div class='tags'>{domains.map((domain) => <span class='tag'>{domain}</span>)}</div></div>
        </div>
        <h3>Find me online</h3>
        <ul class='social-list'>
          {SocialLinks.map((link) => <li><a href={link.url}><span aria-hidden='true'>{link.icon}</span>{link.label}</a></li>)}
        </ul>
      </div>
      <div>
        <h2>{cvProfile.title}</h2>
        <p>{cvProfile.professionalSummary}</p>
        <p>{cvProfile.automationSummary}</p>
        <h3>Recognized for</h3>
        <ul class='recognition-list'>{cvProfile.highlights.map((item) => <li>{item}</li>)}</ul>
      </div>
    </section>

    <section id='experience' aria-labelledby='timeline-title'>
      <h2 id='timeline-title'>Work experience</h2>
      <ol class='timeline'>
        {workExperiences.map((experience) => (
          <li>
            <div class='timeline-head'><h3>{experience.company}</h3><span class='tag'>{experience.role}</span></div>
            <p class='post-meta'>{startedAgo(experience.start)} ago for {monthsBetween(experience.start, experience.end)} months · {projectCounts[experience.company]} projects {experience.end ? '' : '· Current'}</p>
            <p>{experience.description}</p>
          </li>
        ))}
      </ol>
    </section>

    <section id='skills' aria-labelledby='skills-title'>
      <h2 id='skills-title'>Skills</h2>
      <p class='muted'>Qualitative levels based on repeated project work and hands-on delivery—not percentages or certifications.</p>
      <div class='form-control skill-picker'>
        <label for='skill-search'>Search skills</label>
        <input id='skill-search' type='search' placeholder='Try Django, React, PostgreSQL…' autocomplete='off' />
      </div>
      <p id='skill-feedback' class='skill-feedback' aria-live='polite'>Select skills to see how well we match.</p>
      {skillGroups.map((group) => (
        <div class='skill-group' data-skill-group>
          <h3>{group.label}</h3>
          <p class='muted'>{group.description}</p>
          <div class='skill-cloud' aria-label={`${group.label} skills`}>
            {uniqueSkills
              .filter((skill) => getSkillProficiency(skill.label) === group.value)
              .map((skill) => <button class='skill-chip' type='button' aria-pressed='false' data-label={skill.label}>{skill.label}</button>)}
          </div>
        </div>
      ))}
    </section>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const search = document.querySelector<HTMLInputElement>('#skill-search')
  const chips = [...document.querySelectorAll<HTMLButtonElement>('.skill-chip')]
  const feedback = document.querySelector<HTMLParagraphElement>('#skill-feedback')
  const messages = [
    'Select skills to see how well we match.',
    'Great start — that skill is in my toolkit.',
    'Perfect match! These skills are right up my alley. 🎯',
    "We've got a winner — exactly what you're looking for. 🏆",
    'Bingo! This combination is in my toolkit. 🎉',
    "Jackpot! I've got these skills covered. 💰",
  ]
  const updateFeedback = () => {
    const selected = chips.filter((chip) => chip.ariaPressed === 'true').length
    if (feedback) feedback.textContent = selected > 5 ? `Mic drop! ${selected} matching skills. 🎤` : messages[selected]
  }
  search?.addEventListener('input', () => {
    const term = search.value.trim().toLowerCase()
    for (const chip of chips) chip.hidden = !chip.dataset.label?.toLowerCase().includes(term)
    for (const group of document.querySelectorAll<HTMLElement>('[data-skill-group]')) {
      group.hidden = ![...group.querySelectorAll<HTMLButtonElement>('.skill-chip')].some((chip) => !chip.hidden)
    }
  })
  for (const chip of chips) {
    chip.addEventListener('click', () => {
      chip.ariaPressed = chip.ariaPressed === 'true' ? 'false' : 'true'
      updateFeedback()
    })
  }
</script>
