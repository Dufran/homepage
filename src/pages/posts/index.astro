---
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
)
---

<BaseLayout title='Posts — Oleksandr Korol' description='Engineering notes by Oleksandr Korol'>
  <section class='content'>
    <p class='eyebrow'>Writing</p>
    <h1>Posts</h1>
    <p class='lede'>Notes about software engineering, tools, and things I learn.</p>
    <ul class='post-list'>
      {
        posts.map((post) => (
          <li class='post-card'>
            <a href={`/posts/${post.id}/`}>{post.data.title}</a>
            <p>{post.data.description}</p>
            <time class='post-meta' datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('en', {
                day: 'numeric',
                month: 'long',
                year: 'numeric',
              })}
            </time>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
