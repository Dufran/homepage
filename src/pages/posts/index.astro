---
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
)
---

<BaseLayout title='Posts — Oleksandr Korol' description='Engineering notes by Oleksandr Korol'>
  <section class='content'>
    <p class='eyebrow'>Writing</p>
    <h1>Posts</h1>
    <p class='lede'>Notes about software engineering, tools, and things I learn.</p>
    <p class='post-order'>Newest first</p>
    <ol class='post-timeline' aria-label='Posts, newest first'>
      {
        posts.map((post) => (
          <li>
            <time class='post-timeline-date' datetime={post.data.pubDate.toISOString()}>
              <span>{post.data.pubDate.toLocaleDateString('en', { month: 'short' })}</span>
              <strong>{post.data.pubDate.getDate()}</strong>
              <span>{post.data.pubDate.getFullYear()}</span>
            </time>
            <article class='post-card'>
              <a href={`/posts/${post.id}/`}>{post.data.title}</a>
              <p>{post.data.description}</p>
              <div class='tags' aria-label='Tags'>
                {post.data.tags.map((tag) => <span class='tag'>#{tag}</span>)}
              </div>
            </article>
          </li>
        ))
      }
    </ol>
  </section>
</BaseLayout>
