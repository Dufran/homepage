{
	"[css]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[django-html]": {
		"editor.defaultFormatter": "monosans.djlint"
	},
	"[javascript]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[json]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[jsonc]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[markdown]": {
		"editor.defaultFormatter": "DavidAnson.vscode-markdownlint"
	},
	"[postcss]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[python]": {
		"editor.defaultFormatter": "charliermarsh.ruff"
	},
	"[typescript]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[typescriptreact]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"biome.configurationPath": "./frontend/biome.json",
	"biome.enabled": true,
	"biome.lsp.bin": {
		"darwin-arm64": "./frontend/node_modules/@biomejs/cli-darwin-arm64/biome",
		"darwin-x64": "./frontend/node_modules/@biomejs/cli-darwin-x64/biome",
		"linux-x64": "./frontend/node_modules/@biomejs/cli-linux-x64/biome",
		"win32-x64": "./frontend/node_modules/@biomejs/cli-win32-x64/biome.exe"
	},
	"biome.requireConfiguration": true,
	"github.copilot.chat.commitMessageGeneration.instructions": [
		{
			"file": ".github/copilot-commit-message-instructions.md"
		}
	],
	"python.analysis.autoImportCompletions": true,
	"python.analysis.extraPaths": [
		"${workspaceFolder}/backend",
		"${workspaceFolder}/backend/.venv/"
	],
	"python.analysis.include": ["./backend"],
	"python.analysis.indexing": true,
	"python.analysis.packageIndexDepths": [
		{
			"depth": 10,
			"includeAllSymbols": true,
			"name": ""
		}
	],
	"python.analysis.typeCheckingMode": "off",
	"python.autoComplete.extraPaths": ["${workspaceFolder}/backend"],
	"python.defaultInterpreterPath": "${workspaceFolder}/backend/.venv/bin/python",
	"python.testing.autoTestDiscoverOnSaveEnabled": true,
	"python.testing.autoTestDiscoverOnSavePattern": "**/tests*.py",
	"python.testing.cwd": "${workspaceFolder}/backend",
	"python.testing.pytestEnabled": false,
	"python.testing.unittestArgs": ["--noinput"],
	"python.testing.unittestEnabled": true,
	"ruff.args": [
		"--line-length",
		"120",
		"--config=${workspaceFolder}/backend/pyproject.toml"
	],
	"typescript.tsdk": "./node_modules/typescript/lib"
}
